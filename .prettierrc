{
  "semi": true,
  "trailingComma": "es5",
  "singleQuote": true,
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "overrides": [
    {
      "files": ["*.yaml", "*.yml"],
      "options": {
        "parser": "yaml",
        "singleQuote": false,
        "quoteProps": "consistent"
      }
    }
  ]
}
