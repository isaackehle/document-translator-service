# Application
PROJECT_NAME=FastAPI Application
API_V1_STR=/api/v1

# Database (Supabase PostgreSQL)
# Get connection string from Supabase Dashboard > Project Settings > Database
# Format: postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:your-password@db.xxxxx.supabase.co:5432/postgres


# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_HOSTS=["*"]

export LOCALSTACK_AUTH_TOKEN="ls-...."
