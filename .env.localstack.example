# LocalStack Environment Configuration
# Copy this file to .env.localstack for local development

# LocalStack authentication token (required for LocalStack Pro or advanced features)
LOCALSTACK_AUTH_TOKEN=ls-.your-auth-token-here

# Volume directory for data persistence
LOCALSTACK_VOLUME_DIR=./localstack-volume

# AWS credentials (required for LocalStack to work)
AWS_ACCESS_KEY_ID=localstack
AWS_SECRET_ACCESS_KEY=localstack

# AWS region
AWS_DEFAULT_REGION=us-east-1
