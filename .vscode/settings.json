{
  "[python]": {
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.fixAll.pylance": "explicit",
      "source.organizeImports": "explicit",
      "source.organizeImports.pylance": "explicit"
    },
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true
  },
  "cSpell.words": [
    "asyncio",
    "asyncpg",
    "boto",
    "fastapi",
    "fetchval",
    "httpx",
    "localstack",
    "minioadmin",
    "moto",
    "onupdate",
    "passlib",
    "poolclass",
    "pycache",
    "pydantic",
    "pytest",
    "rdctl",
    "redoc",
    "schemaname",
    "sqlalchemy",
    "Supabase",
    "TIMESTAMPTZ",
    "uvicorn",
    "venv"
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit",
    "source.organizeImports.pylance": "explicit"
  },
  "editor.quickSuggestions": {
    "strings": true
  },
  "python.analysis.autoImportCompletions": true,
  "python.autoComplete.extraPaths": [".", "./app"],
  "python.linting.enabled": true,
  "python.linting.flake8Enabled": true,
  "python.linting.pylintEnabled": false,
  "ruff.enable": true,
  "ruff.organizeImports": true,
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#6254ee",
    "activityBar.background": "#6254ee",
    "activityBar.foreground": "#e7e7e7",
    "activityBar.inactiveForeground": "#e7e7e799",
    "activityBarBadge.background": "#74150c",
    "activityBarBadge.foreground": "#e7e7e7",
    "commandCenter.border": "#e7e7e799",
    "sash.hoverBorder": "#6254ee",
    "statusBar.background": "#3826e9",
    "statusBar.foreground": "#e7e7e7",
    "statusBarItem.hoverBackground": "#6254ee",
    "statusBarItem.remoteBackground": "#3826e9",
    "statusBarItem.remoteForeground": "#e7e7e7",
    "titleBar.activeBackground": "#3826e9",
    "titleBar.activeForeground": "#e7e7e7",
    "titleBar.inactiveBackground": "#3826e999",
    "titleBar.inactiveForeground": "#e7e7e799"
  },
  "peacock.color": "#3826e9",
  "github.copilot.chat.model": "ollama",
  "github.copilot.chat.customOAIModels": {
    "ollama": {
      "endpoint": "http://localhost:11434/v1",
      "model": "qwen3.2-coder:7b"
    }
  },

  "python.analysis.diagnosticMode": "openFilesOnly",
  "python.analysis.indexing": false,
  "python.analysis.autoSearchPaths": false,

  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.venv/**": true,
    "**/venv/**": true,
    "**/env/**": true,
    "**/__pycache__/**": true,
    "**/.pytest_cache/**": true,
    "**/.mypy_cache/**": true,
    "**/.ruff_cache/**": true,
    "**/.tox/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/*.pyc": true,
    "**/*.gz": true
  },

  "search.exclude": {
    "**/.venv": true,
    "**/venv": true,
    "**/env": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/.tox": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/*.pyc": true,
    "**/*.gz": true
  }
}
